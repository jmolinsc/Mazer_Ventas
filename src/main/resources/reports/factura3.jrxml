	<parameter name="ventaId" class="java.lang.Long"/>
	<queryString>
		<![CDATA[select v.id,dv.cantidad,v.estado,v.fecha,v.total,
v.cliente_id,dv.producto_id,v.mov,v.movid,
v.estatus,dv.precio_unitario,dv.subtotal,
c.nombre,c.email,c.actividad_economica,c.direccion,
c.nit,c.nrc,p.nombre as producto
from ventas v 
inner join ventad dv on dv.venta_id=v.id
inner join clientes c on c.id=v.cliente_id
inner join productos p on p.id=dv.producto_id
WHERE v.id = $P{ventaId}]]>
	</queryString>
	<field name="id" class="java.lang.Integer"/>
	<field name="cantidad" class="java.lang.Integer"/>
	<field name="estado" class="java.lang.String"/>
	<field name="fecha" class="java.util.Date"/>
